# ============================================
# IBMS Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ============================================

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://ibms:ibms_dev_password@localhost:5432/ibms?schema=public

# --- JWT (RS256 asymmetric keys) ---
# Generate keys:
#   mkdir keys
#   openssl genrsa -out keys/access-private.pem 2048
#   openssl rsa -in keys/access-private.pem -pubout -out keys/access-public.pem
JWT_ACCESS_PRIVATE_KEY_PATH=keys/access-private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=keys/access-public.pem

# Refresh token secret (use a long random string, 32+ chars)
JWT_REFRESH_SECRET=CHANGE_ME_use_a_random_string_at_least_32_characters_long

# Token expiry durations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend ---
# URL of the frontend app (used for invitation links, password reset links)
FRONTEND_URL=http://localhost:3000

# --- Server ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# --- Rate Limiting ---
# TTL in seconds, LIMIT = max requests per TTL window
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Swagger ---
# Set to "false" in production
SWAGGER_ENABLED=true

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
